  "required": [
    "strategy_id",
    "symbol",
    "side",
    "confidence",
    "thesis",
    "entry_reference",
    "stop_price",
    "expected_holding_period",
    "invalidation_reason"
  ],
  "title": "TradeProposal",
  "type": "object"
